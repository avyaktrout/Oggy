# ==============================================================================
# Oggy Environment Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# ------------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=oggy
POSTGRES_PASSWORD=oggy_dev_password
POSTGRES_DB=oggy_db

# Full database URL (used by learning service)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://oggy:oggy_dev_password@localhost:5432/oggy_db

# ------------------------------------------------------------------------------
# Redis Configuration
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Service Ports
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
MEMORY_SERVICE_PORT=3000
LEARNING_SERVICE_PORT=8000

# ------------------------------------------------------------------------------
# Service URLs (for inter-service communication)
# ------------------------------------------------------------------------------
MEMORY_SERVICE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Authentication (Optional in dev, required in production)
# ------------------------------------------------------------------------------
# INTERNAL_API_KEY=your-secret-key-here
# Uncomment and set for production deployments

# ------------------------------------------------------------------------------
# OpenAI API (Required for embeddings and LLM scoring)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# ------------------------------------------------------------------------------
# OpenTelemetry Configuration
# ------------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=oggy-services

# ==============================================================================
# Docker-Specific Overrides
# ==============================================================================
# When running in Docker Compose, these are automatically set:
# POSTGRES_HOST=postgres
# REDIS_HOST=redis
# MEMORY_SERVICE_URL=http://memory-service:3000
# DATABASE_URL=postgresql://oggy:oggy_password@postgres:5432/oggy_db
